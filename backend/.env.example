# Lumina Bench — Production Environment Variables
# Copy this file to .env and edit before running docker compose up

# JWT signing key — CHANGE THIS in production
SECRET_KEY=change-me-in-production

# SQLite database path (persisted via /data volume in Docker)
DATABASE_URL=sqlite:///data/lumina_bench.db

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://yourdomain.com